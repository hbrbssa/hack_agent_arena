# Copy to .env. For fair scoring everyone uses Groq (free, no billing) — fill this in:
GROQ_API_KEY=             # free key: console.groq.com  (sign in -> API Keys -> Create)

# Other backends work too, for LOCAL DEV only — scored runs must use Groq (see README):
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=          # free tier: aistudio.google.com
# OPENROUTER_API_KEY=      # some free models: openrouter.ai

# LLM provider (default model is OpenRouter's meta-llama/llama-3.1-8b-instruct):
# MODEL=meta-llama/llama-3.1-8b-instruct   # any OpenRouter model, or claude-* (Anthropic)
# LLM_PROVIDER=                  # auto: 'anthropic' if MODEL starts with 'claude', else 'openrouter'
# OPENROUTER_API_KEY=            # required for OpenRouter models; keep in .env, NEVER commit
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_TIMEOUT=120

# Optional overrides:
# MODEL=groq/llama-3.3-70b-versatile   # default; or gemini/..., anthropic/..., ollama/llama3.1
# APPWORLD_EXPERIMENT=team_yourname
# APPWORLD_DATASET=dev           # dev | smoke | testplan | test_normal
# MAX_TASKS=0                    # 0 = all tasks in the split
# MAX_INTERACTIONS=40            # ReAct turns per task (env cap is 1000)
# MAX_TOKENS=4096               # LLM response budget per turn
# TEMPERATURE=0.0               # determinism for reproducible eval
# MAX_OBS_CHARS=4000            # truncate long observations fed back to the model
# MAX_RETRIES=3                 # bounded error-recovery before a stronger reset nudge
# ENABLE_PLANNING=true          # one planning call before the ReAct loop
# VERBOSE=false                 # per-step logging

# HydraDB — optional cross-task persistence/context layer (see hydra.py):
# HYDRADB_API_KEY=              # set to enable HydraDB; keep in .env, NEVER commit
# ENABLE_HYDRA=true             # default: on when HYDRADB_API_KEY is set
# HYDRA_TENANT_ID=appworld_agent
# HYDRA_BASE_URL=https://api.hydradb.com
# HYDRA_TIMEOUT=10
# HYDRA_MAX_CONTEXT=6           # memory chunks injected at the top of each task
